# Use ONE of these (OpenRouter recommended if you don't have an OpenAI platform key):
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the model (defaults to anthropic/claude-sonnet-4.6 on OpenRouter, gpt-4.1 for direct OpenAI)
# AGENT_MODEL=anthropic/claude-sonnet-4.6
