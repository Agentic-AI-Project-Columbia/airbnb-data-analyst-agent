# Use ONE of these (OpenRouter recommended if you don't have an OpenAI platform key):
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the model (defaults to openai/gpt-4.1 for OpenRouter, gpt-4.1 for OpenAI)
# AGENT_MODEL=openai/gpt-4.1
