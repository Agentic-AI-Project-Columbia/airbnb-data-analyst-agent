# ---------- Vertex AI (required) ----------
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=global

# Comma-separated frontend origins allowed to call the backend.
# Defaults to localhost development origins when unset.
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model override (default: google/gemini-3.1-pro-preview)
# AGENT_MODEL=google/gemini-3.1-pro-preview
